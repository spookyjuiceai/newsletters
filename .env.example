# Newsletter Publish Script — Environment Variables
# Copy to .env and fill in actual values
# NEVER commit .env to git

# Beehiiv (Newsletter Platform)
BEEHIIV_API_KEY=your_beehiiv_api_key_here
BEEHIIV_PUB_ID=pub_98000f92-fc4d-42b6-aeb6-a1d21f2d7f82

# Discord (Webhook for #newsletter or #announcements)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# X / Twitter (OAuth 1.0a — from developer.x.com app "SpookyJuiceAI")
X_CONSUMER_KEY=your_consumer_key
X_CONSUMER_SECRET=your_consumer_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_TOKEN_SECRET=your_access_token_secret
